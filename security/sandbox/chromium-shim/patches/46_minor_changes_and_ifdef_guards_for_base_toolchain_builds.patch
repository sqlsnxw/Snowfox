Minor changes and #if guards to allow for base toolchain builds.

* __STDCPP_DEFAULT_NEW_ALIGNMENT__ not available on some GCC - remove its use.
* span.h uses <ranges> which the sixgill GCC 10 plugin cannot handle - implement
  using memcpy for GCC
* lock_impl_posix.cc: #pragma clang diagnostic not understood by GCC - guard
  with #if defined(__clang__)
* utf_string_conversions.h: static_assert(false) in templates is ill-formed
  pre-C++23 in GCC - make condition depend on N
* callback.h: Same static_assert(false) issue in template methods - depend on
  Signature
* time.h: Defaulted operator<=> fails because ClampedNumeric has no <=> -
  explicit implementation using .RawValue()
* bpf_dsl.cc: GCC doesn't treat [[noreturn]] on a destructor as sufficient to
  suppress the missing-return warning - add return 0
* string_util_impl_helpers.h: StringOrStringView concept with default template
  param breaks in GCC return-type constraints - inline std::remove_cvref_t<T>
  directly


diff --git a/base/allocator/partition_allocator/src/partition_alloc/partition_alloc_forward.h b/base/allocator/partition_allocator/src/partition_alloc/partition_alloc_forward.h
--- a/base/allocator/partition_allocator/src/partition_alloc/partition_alloc_forward.h
+++ b/base/allocator/partition_allocator/src/partition_alloc/partition_alloc_forward.h
@@ -29,19 +29,23 @@ namespace internal {
 // Alignment has two constraints:
 // - Alignment requirement for scalar types: alignof(std::max_align_t)
 // - Alignment requirement for operator new().
 //
 // The two are separate on Windows 64 bits, where the first one is 8 bytes, and
 // the second one 16. We could technically return something different for
 // malloc() and operator new(), but this would complicate things, and most of
 // our allocations are presumably coming from operator new() anyway.
+#if defined(__STDCPP_DEFAULT_NEW_ALIGNMENT__)
 constexpr inline size_t kAlignment =
     std::max(alignof(max_align_t),
              static_cast<size_t>(__STDCPP_DEFAULT_NEW_ALIGNMENT__));
+#else
+constexpr inline size_t kAlignment = alignof(max_align_t);
+#endif
 static_assert(base::bits::HasSingleBit(kAlignment),
               "Alignment must be power of two.");
 static_assert(kAlignment <= 16,
               "PartitionAlloc doesn't support a fundamental alignment larger "
               "than 16 bytes.");

 constexpr inline size_t kAlignmentIndex = base::bits::CountrZero(kAlignment);
 static_assert(kAlignment == (1 << kAlignmentIndex));
diff --git a/base/check_op.cc b/base/check_op.cc
--- a/base/check_op.cc
+++ b/base/check_op.cc
@@ -11,7 +11,11 @@
 #include <sstream>
 
 #include "base/compiler_specific.h"
+#if defined(__clang__)
+// span.h uses <ranges> which the sixgill GCC 10 plugin (used for hazard
+// analysis) cannot handle; guard the span-heavy implementation below.
 #include "base/containers/span.h"
+#endif
 #include "base/logging.h"
 #include "base/strings/cstring_view.h"
 
@@ -73,11 +77,18 @@ char* CheckOpValueStr(std::string_view v) {
   // overloads. The API contract is that the caller uses free() to release the
   // pointer returned here.
   char* ret = static_cast<char*>(malloc(v.size() + 1u));
+#if defined(__clang__)
   auto [val, nul] =
       // SAFETY: We allocated `ret` as `v.size() + 1` bytes above.
       UNSAFE_BUFFERS(base::span<char>(ret, v.size() + 1u)).split_at(v.size());
   val.copy_from(v);
   nul.copy_from(base::span_from_ref('\0'));
+#else
+  if (ret) {
+    std::copy(v.begin(), v.end(), ret);
+    ret[v.size()] = 0;
+  }
+#endif
   return ret;
 }
 
