 .../shared_screencast_stream_unittest.cc      | 11 +++++
 .../test/test_screencast_stream_provider.cc   |  2 +
 .../test/test_screencast_stream_provider.h    |  8 +++-
 4 files changed, 53 insertions(+), 12 deletions(-)

