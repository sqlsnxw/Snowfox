with Files("**"):
    BUG_COMPONENT = ("Firefox", "IP Protection")

XPI_NAME = "ipp-activator"
XPI_PKGNAME = "ipp-activator@mozilla.com"

DIST_SUBDIR = ""

# NOTE: Please make sure that all files listed in here are in sync with the ones
# meant to be packaged in the add-on XPI file.

FINAL_TARGET_FILES += [
    "../extension/bg.js",
    "../extension/manifest.json",
]

FINAL_TARGET_FILES.breakages += ["../extension/breakages/**"]
FINAL_TARGET_FILES.conditions += ["../extension/conditions/**"]
FINAL_TARGET_FILES.api.parent += ["../extension/api/parent/**"]
FINAL_TARGET_FILES.api.schemas += ["../extension/api/schemas/**"]
