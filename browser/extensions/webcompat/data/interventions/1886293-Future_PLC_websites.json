{
  "label": "Future PLC websites",
  "bugs": {
    "1886293": {
      "issue": "extra-scrollbars",
      "matches": [
        "*://*.androidcentral.com/*",
        "*://*.creativebloq.com/*",
        "*://*.cyclingnews.com/*",
        "*://*.gamesradar.com/*",
        "*://*.imore.com/*",
        "*://*.itpro.com/*",
        "*://*.laptopmag.com/*",
        "*://*.livescience.com/*",
        "*://*.loudersound.com/*",
        "*://*.musicradar.com/*",
        "*://*.pcgamer.com/*",
        "*://*.techradar.com/*",
        "*://*.tomshardware.com/*",
        "*://*.windowscentral.com/*"
      ]
    }
  },
  "css": {
    "fix_trending_scrollbar": ".trending__list { scrollbar-width: thin; scrollbar-color: var(--trending-scrollbar-color) var(--trending-scrollbar-background-color); }"
  },
  "interventions": [
    {
      "platforms": ["desktop"],
      "css": ["fix_trending_scrollbar"]
    }
  ]
}
