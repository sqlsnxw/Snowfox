{
  "include": ["*.sys.mjs", "types/*.ts"],
  "exclude": ["Interactions.sys.mjs", "PlacesUIUtils.sys.mjs"],
  "extends": "../../../tools/@types/tsconfig.json",

  "compilerOptions": {
    "checkJs": true,
    "strict": true,
    "noImplicitAny": false,
    "strictNullChecks": false,

    "plugins": [
      {
        "transform": "../../../tools/ts/plugins/checkRootOnly.js",
        "transformProgram": true
      }
    ]
  }
}
