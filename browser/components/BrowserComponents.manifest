# The category below is specific to Tabbrowser destruction. For consumers that need to uninitialize during
# window unload, use 'browser-window-unload' instead.
category browser-window-unload-tabbrowser chrome://browser/content/tabbrowser/tabbrowser.js Tabbrowser.destroy

category browser-window-final-unload resource:///modules/BrowserDOMWindow.sys.mjs BrowserDOMWindow.teardownInWindow

