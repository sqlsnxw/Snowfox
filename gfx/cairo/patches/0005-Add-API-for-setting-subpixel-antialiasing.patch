@@ -462,6 +464,8 @@ _cairo_surface_copy_similar_properties (cairo_surface_t *surface,
 	_cairo_font_options_fini (&options);
     }
 
+    surface->permit_subpixel_antialiasing = other->permit_subpixel_antialiasing;
