Program("extra-link-deps-program")

GENERATED_FILES += ["generated.plist"]
plist = GENERATED_FILES["generated.plist"]
plist.script = "generate.py:generate"
plist.inputs = ["plist-data"]

EXTRA_LINK_DEPS += [
    "!generated.plist",
    "dep.txt",
]
